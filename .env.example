# ============================================================
# C1PH3R FSOCIETY — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://c1ph3rfsociety.com
NEXT_PUBLIC_SITE_NAME="C1ph3r Fsociety"

# --- PayPal ---
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
# Use 'sandbox' for testing, 'live' for production
PAYPAL_MODE=sandbox

# --- Razorpay ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# --- Email (Nodemailer) ---
# Use Gmail App Password, SendGrid, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="C1ph3r Fsociety <noreply@c1ph3rfsociety.com>"
EMAIL_ADMIN=rahulthegreat2001@gmail.com

# --- UploadThing (file uploads) ---
UPLOADTHING_SECRET=sk_live_xxxxx
UPLOADTHING_APP_ID=your-app-id

# --- Admin ---
# Strong secret for admin session signing
ADMIN_SECRET=generate-a-strong-random-secret-here

# --- Analytics (optional) ---
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=c1ph3rfsociety.com
